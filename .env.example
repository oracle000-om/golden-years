DATABASE_URL="postgresql://user:password@host:5432/dbname"
GEMINI_API_KEY="your-gemini-api-key"
NCBI_API_KEY="your-ncbi-api-key"          # Optional — PubMed E-utilities (https://www.ncbi.nlm.nih.gov/account/)
ZILLIZ_ENDPOINT="https://xxx.api.gcp-us-west1.zillizcloud.com" # Zilliz Cloud cluster endpoint
ZILLIZ_TOKEN="your-zilliz-api-token"       # Zilliz Cloud API token
API_KEYS="sniff:your-api-key-here"         # Comma-separated name:secret pairs for /api/v1/* auth
API_JWT_SECRET="your-jwt-signing-secret"   # Optional — for JWT-based auth
API_AUTH_REQUIRED="true"                   # Set to "false" to disable auth in dev
CORS_ALLOWED_ORIGINS="*"                   # Comma-separated origins for /api/v1/* CORS
