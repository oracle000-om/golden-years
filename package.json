{
  "name": "golden-years",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "migrate:deploy": "prisma migrate deploy",
    "lint": "eslint",
    "seed": "npx prisma db seed",
    "scrape": "npx tsx scraper/index.ts",
    "scrape:shelter-stats": "npx tsx scraper/run-shelter-stats.ts",
    "scrape:opendata": "npx tsx scraper/run-opendata.ts",
    "scrape:breeds": "npx tsx scraper/run-breed-db.ts",
    "scrape:petango": "npx tsx scraper/run-petango.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}